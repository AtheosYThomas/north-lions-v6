rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // 會員私有檔案：路徑需包含 Firebase Auth uid（與 client 上傳路徑對齊）
    match /members/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // 舊版憑證上傳路徑（歷史資料／尚未遷移的檔案）：僅限已登入者存取（仍比公開讀安全）
    // TODO：遷移既有檔案到 members/{uid}/... 後，應改為 deny 或加上更嚴格條件
    match /receipts/{fileName} {
      allow read, write: if request.auth != null;
    }

    // 預設拒絕（關閉舊版「全 bucket 公開讀」）
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
