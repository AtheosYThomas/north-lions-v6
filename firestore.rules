rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Basic helpers
    function isAuthenticated() {
      return request.auth != null;
    }

    // ── isOfficer：與 v7/client、v7/admin、webhook memberProfile 管理權限對齊 ──
    // 1) uid === 'dev-admin'
    // 2) Firebase Auth token.email === 'admin@example.com'
    // 3) members/{uid}：system.role 或 role（字串，不分大小寫）為 admin
    // 4) members/{uid}：isAdmin == true（指定人員）
    // 5) members/{uid}：title / position / organization.title / organization.role 含
    //    「會長、秘書、財務、總管、聯絡」之一
    // 注意：不再讀取 users/{uid} 判斷幹部。

    function memberDoc() {
      return get(/databases/$(database)/documents/members/$(request.auth.uid)).data;
    }

    function memberHasAdminRole(data) {
      return ('system' in data && data.system is map
              && 'role' in data.system
              && data.system.role is string
              && data.system.role.lower() == 'admin')
          || ('role' in data && data.role is string && data.role.lower() == 'admin');
    }

    function memberHasExplicitIsAdmin(data) {
      return 'isAdmin' in data && data.isAdmin == true;
    }

    function memberTextMatchesManagementKeyword(text) {
      return text is string
          && (text.matches('.*會長.*')
              || text.matches('.*秘書.*')
              || text.matches('.*財務.*')
              || text.matches('.*總管.*')
              || text.matches('.*聯絡.*'));
    }

    function memberHasOfficerPosition(data) {
      return ('position' in data && data.position is string && memberTextMatchesManagementKeyword(data.position))
          || ('title' in data && data.title is string && memberTextMatchesManagementKeyword(data.title))
          || ('organization' in data && data.organization is map
              && 'title' in data.organization && data.organization.title is string
              && memberTextMatchesManagementKeyword(data.organization.title))
          || ('organization' in data && data.organization is map
              && 'role' in data.organization && data.organization.role is string
              && memberTextMatchesManagementKeyword(data.organization.role));
    }

    function memberDocGrantsOfficer() {
      return exists(/databases/$(database)/documents/members/$(request.auth.uid))
          && (memberHasExplicitIsAdmin(memberDoc())
              || memberHasAdminRole(memberDoc())
              || memberHasOfficerPosition(memberDoc()));
    }

    function authEmailIsExampleAdmin() {
      return 'email' in request.auth.token
          && request.auth.token.email is string
          && request.auth.token.email == 'admin@example.com';
    }

    function isOfficer() {
      return isAuthenticated() && (
        request.auth.uid == 'dev-admin' ||
        authEmailIsExampleAdmin() ||
        memberDocGrantsOfficer()
      );
    }

    // Check if user is an official member
    function isOfficialMember() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/members/$(request.auth.uid)) &&
        (get(/databases/$(database)/documents/members/$(request.auth.uid)).data.status.membershipType == '正會員' ||
         get(/databases/$(database)/documents/members/$(request.auth.uid)).data.status.membershipType == '創會會員' ||
         get(/databases/$(database)/documents/members/$(request.auth.uid)).data.status.membershipType == '贊助會員' ||
         get(/databases/$(database)/documents/members/$(request.auth.uid)).data.status.membershipType == '正式');
    }

    // Default: deny everything unless matched below
    match /{document=**} {
      allow read, write: if false;
    }

    // Events: public read; only officers may write
    match /events/{eventId} {
      allow read: if true; // public
      allow write: if isOfficer();
    }

    // Announcements: authenticated users may read; only officers may write
    match /announcements/{announcementId} {
      allow read: if isAuthenticated();
      allow write: if isOfficer();
    }

    // Users: owner or officer may read; only officer may write
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isOfficer());
      allow write: if isOfficer();
    }

    // Members: all authenticated users may read; owner or officer may write
    match /members/{memberId} {
      allow read: if isOfficer() || isOfficialMember() || request.auth.uid == memberId;
      allow write: if isAuthenticated() && (request.auth.uid == memberId || isOfficer());
    }

    // Registrations：僅本人或幹部可讀；建立時禁止冒用他人 memberId
    match /registrations/{regId} {
      allow create: if isAuthenticated() && (
          request.resource.data.info.memberId == request.auth.uid
          || isOfficer()
      );
      allow read: if isOfficer()
          || (isAuthenticated() && resource.data.info.memberId == request.auth.uid);
      allow update, delete: if isOfficer()
          || (isAuthenticated() && resource.data.info.memberId == request.auth.uid);
    }

    // Donations: only officers can write, owners and officers can read
    match /donations/{donationId} {
      allow read: if isOfficer() || (isAuthenticated() && resource.data.memberId == request.auth.uid);
      allow write: if isOfficer();
    }

    // Billing Campaigns: only officers can write, all authenticated can read
    match /billing_campaigns/{campaignId} {
      allow read: if isAuthenticated();
      allow write: if isOfficer();
    }

    // Billing Records: officers can read/write. Owners can read and update their own
    match /billing_records/{recordId} {
      allow read: if isOfficer() || (isAuthenticated() && resource.data.memberId == request.auth.uid);
      allow create, delete: if isOfficer();
      // 會員更新：禁止竄改歸戶／活動等關鍵欄位（避免水平越權改帳）
      allow update: if isOfficer() || (
        isAuthenticated()
        && resource.data.memberId == request.auth.uid
        && request.resource.data.memberId == resource.data.memberId
        && (!('campaignId' in resource.data)
            || request.resource.data.campaignId == resource.data.campaignId)
        && request.resource.data.billing == resource.data.billing
      );
    }

    // Notifications: users can read their own or broadcast notifications; only officers can write
    match /notifications/{notifId} {
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid ||
        resource.data.userId == 'all' ||
        (isOfficer() && resource.data.userId == 'admin')
      );
      allow write: if isOfficer();
    }

    // Chat/message logs: only officers can read from admin feedback console
    // Webhook writes use Admin SDK and bypass security rules.
    match /message_logs/{logId} {
      allow read: if isOfficer();
      allow write: if false;
    }

    // 管理行為稽核：僅幹部可建立與讀取；禁止更新／刪除以保真實性
    match /admin_audit_logs/{logId} {
      allow create: if isOfficer()
          && request.resource.data.operatorUid == request.auth.uid
          && request.resource.data.action is string
          && 'timestamp' in request.resource.data;
      allow read: if isOfficer();
      allow update, delete: if false;
    }
  }
}
