{
  "name": "client",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc -b --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:guest": "playwright test e2e/mobile-nav.spec.ts --grep \"手機版導覽列\"",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed"
  },
  "dependencies": {
    "@line/liff": "^2.28.0",
    "browser-image-compression": "^2.0.2",
    "canvas-confetti": "^1.9.4",
    "firebase": "^12.11.0",
    "pinia": "^3.0.4",
    "qrcode.vue": "^3.8.1",
    "shared": "*",
    "vue": "^3.5.30",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^24.12.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/tsconfig": "^0.9.0",
    "autoprefixer": "^10.4.27",
    "jsdom": "^29.0.2",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.3",
    "vite": "^8.0.1",
    "vitest": "^4.1.5",
    "vue-tsc": "^3.2.5"
  }
