{
  "compilerOptions": {
    "module": "commonjs",
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "outDir": "lib",
    "sourceMap": true,
    "strict": true,
    "target": "es2021",
    "skipLibCheck": true,
    "paths": {
      "shared": ["../shared/src/index.ts"]
    }
  },
  "compileOnSave": true,
  "include": ["src"],
  "exclude": ["node_modules"]
}
